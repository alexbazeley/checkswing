/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# data.json is regenerated at every Cloudflare build (from data/master.db).
# 5-minute cache lets the freshness badge breathe; must-revalidate keeps it
# from getting too stale on rapid push cycles.
/data.json
  Cache-Control: public, max-age=300, must-revalidate

# state_data.json (Phase-4 state layer) — same policy as data.json so a state
# refresh / new-jurisdiction deploy propagates to the edge promptly instead of
# serving a stale copy.
/state_data.json
  Cache-Control: public, max-age=300, must-revalidate

# Always re-fetch index.html — small file, version-controlled, changes per deploy.
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Assets are fingerprinted by content (Cloudflare adds ETag); cache aggressively.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
