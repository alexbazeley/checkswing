# Secrets
.env

# Database transient files (journal/WAL/shm); the master.db file itself is
# committed because the Cloudflare deploy regenerates mockup/data.json from
# it at build time. master.db is the project's source of truth (CLAUDE.md
# §1.4 — raw payloads are ground truth but live outside git; master.db is
# the rebuildable derivative the static site depends on).
data/master.db-journal
data/master.db-wal
data/master.db-shm

# Runtime lock file from scripts/refresh.py — released on clean exit, but a
# killed/crashed run can leave it behind.
data/.refresh.lock

# Snapshots and raw payloads — large, regenerable, never deployed
data/snapshots/
data/raw/

# CSV exports are derivative — regenerable
data/donations/

# mockup/data.json and mockup/provenance.json are generated at Cloudflare build
# time from data/master.db and catalog/PROVENANCE_LOG.md respectively.
# Local previews regenerate them via `python mockup/build_data.py`.
mockup/data.json
mockup/provenance.json

# Session-local state: handoff briefs, scratch notes, editor launch configs.
.claude/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
.python-version
*.egg-info/

# Editor
.vscode/
.idea/
*.swp
.DS_Store
