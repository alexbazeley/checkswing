# Secrets
.env

# Database transient files (journal/WAL/shm); the master.db file itself is
# committed because the Cloudflare deploy regenerates mockup/data.json from
# it at build time. master.db is the project's source of truth (GOVERNANCE.md
# §1.4 — raw payloads are ground truth but live outside git; master.db is
# the rebuildable derivative the static site depends on).
data/master.db-journal
data/master.db-wal
data/master.db-shm

# Runtime lock files; released on clean exit, but a killed/crashed run can
# leave them behind. Treated the same as the master.db journal/WAL/shm.
data/.refresh.lock
data/.committees_ingest.lock

# Snapshots and raw payloads — large, regenerable, never deployed
data/snapshots/
data/raw/

# CSV exports are derivative — regenerable
data/donations/

# REVIEW_QUEUE.md is a human-readable mirror of the review_queue table in
# master.db (the queryable source of truth). It grew unbounded (~18 MB, never
# pruned) and diffed poorly, so it is no longer tracked. Regenerate locally with
# `python -m scripts.cli export-review-queue`.
catalog/REVIEW_QUEUE.md

# mockup/data.json and mockup/provenance.json are generated at Cloudflare build
# time from data/master.db and catalog/PROVENANCE_LOG.md respectively.
# Local previews regenerate them via `python mockup/build_data.py`.
mockup/data.json
mockup/provenance.json

# Session-local state: handoff briefs, scratch notes, editor launch configs.
.claude/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
.python-version
*.egg-info/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Per-committee beneficiary chunks — generated at build time from master.db
# alongside data.json (which carries only the lightweight index).
mockup/beneficiaries/
