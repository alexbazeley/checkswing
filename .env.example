# Copy to .env and fill in. .env is gitignored.
# Get a free FEC API key at https://api.data.gov/signup/
FEC_API_KEY=

# Phase 3 (legislation index). Congress.gov is fronted by api.data.gov, so a
# single api.data.gov key works for BOTH FEC and Congress.gov — you can reuse
# the same value here. The legislation fetchers fall back to FEC_API_KEY if
# CONGRESS_API_KEY is unset. https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# Phase 4 (state campaign finance, CA pilot). The Tier-1 source — California's
# CAL-ACCESS, via the California Civic Data Coalition bulk mirror — needs NO key.
# These keys are only for the OPTIONAL Tier-2 *discovery* aggregators (they surface
# candidate records; the fact is always confirmed against CAL-ACCESS). Leave blank
# to run the pilot portal-only. https://www.followthemoney.org (free myFTM account)
TAP_API_KEY=
FTM_API_KEY=
